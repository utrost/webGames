{
  "dtl": {
    "formula": "deckNumber * (1.0 + modifierBonus)",
    "modifiers": {
      "infested": 0.3,
      "dark": 0.1,
      "decompressed": 0.2,
      "flooded": 0.2,
      "lockdown": 0.1,
      "overgrown": 0.2,
      "unstable": 0.3,
      "hunted": 0.4,
      "entropy": 0.3,
      "singularity": 0.5
    }
  },
  "monster": {
    "hp": { "base": "bodyHP", "formula": "base * (1 + 0.25 * DTL)" },
    "atk": { "base": "bodyATK", "formula": "base * (1 + 0.20 * DTL)" },
    "def": { "base": "bodyDEF", "formula": "base + floor(DTL / 3)" },
    "xp": { "base": "bodyXP", "formula": "base * (1 + 0.15 * DTL)" }
  },
  "resistance": {
    "positiveScaling": 2,
    "negativeScaling": 1,
    "cap": 90
  },
  "weapon": {
    "atk": { "formula": "baseATK * (1 + 0.15 * iLvl)" },
    "durability": { "formula": "baseDur * (1 + 0.10 * iLvl)" },
    "affixStrength": { "formula": "baseEffect * (1 + 0.20 * iLvl)" }
  },
  "armor": {
    "def": { "formula": "baseDEF * (1 + 0.20 * iLvl)" }
  },
